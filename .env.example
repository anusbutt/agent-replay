# AgentReplay V1 — copy to .env and fill in real values. Never commit .env.

# Postgres connection (compose sets this for the local stack; NeonDB URL for hosted)
DATABASE_URL=postgresql+psycopg://agentreplay:agentreplay@db:5432/agentreplay

# The single static API key protecting all backend endpoints (scope guard: nothing more)
AGENTREPLAY_API_KEY=

# Analysis/detection inference — google/gemma-4-31b-it via OpenRouter,
# OpenAI-compatible. AMD-hardware-hosted inference via Fireworks AI is the
# intended production endpoint (swap via this URL) once deployed there.
ANALYSIS_BASE_URL=https://openrouter.ai/api/v1
ANALYSIS_API_KEY=

# Fork live-inference endpoint (OpenAI-compatible; default OpenRouter)
REPLAY_BASE_URL=https://openrouter.ai/api/v1
REPLAY_API_KEY=
